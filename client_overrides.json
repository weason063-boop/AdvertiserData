{
    "_comment": "客户特殊计费规则配置。每个客户可配置单条规则对象或按顺序执行的规则数组，action 类型包括：remove_time_constraint, force_service_type, fixed_rate, exclude_media, media_rate, force_no_fee, custom_label_alias",
    "overrides": {
        "昊一源": {
            "action": "remove_time_constraint",
            "description": "忽略条款中的时间限制（如 '2月起'），强制计算",
            "force_keyword": "Facebook"
        },
        "飞亚达": {
            "action": "force_service_type",
            "description": "强制转为流水类型（忽略代投固定费+点位）",
            "service_type": "流水"
        },
        "农夫山泉": {
            "action": "conditional_zero",
            "description": "条款含 '无代投服务费' 且服务类型为代投时返回 0",
            "condition_keyword": "无代投服务费",
            "condition_service_type": "代投"
        },
        "美的": [
            {
                "action": "media_rate",
                "description": "Google、Facebook、YouTube、TikTok、Yandex、TTD 代投按 5% 计算",
                "media": ["Google", "Facebook", "YouTube", "TikTok", "Yandex", "TTD"],
                "service_type": "代投",
                "rate": 0.05
            },
            {
                "action": "media_rate",
                "description": "Bing、MIQ、Taboola、Pinterest、Linkedin 代投按 8% 计算",
                "media": ["Bing", "MIQ", "Taboola", "Pinterest", "Linkedin"],
                "service_type": "代投",
                "rate": 0.08
            },
            {
                "action": "media_rate",
                "description": "X、Reddit 代投按 6% 计算",
                "media": ["X", "Reddit"],
                "service_type": "代投",
                "rate": 0.06
            },
            {
                "action": "media_rate",
                "description": "Yahoo、Naver 代投按 4% 计算",
                "media": ["Yahoo", "Naver"],
                "service_type": "代投",
                "rate": 0.04
            }
        ],
        "纽莱克": {
            "action": "exclude_media",
            "description": "排除 Facebook 媒介（只计算 Google 代投）",
            "excluded_media": ["Facebook"]
        },
        "上海Liene": {
            "action": "fixed_rate",
            "description": "本月免收固定服务费（保留 10% 点位）",
            "rate": 0.10
        }
    },
    "post_calculation_overrides": {},
    "label_aliases": {
        "哇鹅默认": ""
    }
}
